APP_NAME=Production RAG Assistant
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api
HOST=127.0.0.1
PORT=8000
RELOAD=false
CORS_ORIGINS=http://localhost:5173

VECTOR_STORE_BACKEND=chroma
CHROMA_DIR=data/chroma
HISTORY_DB_PATH=data/history.sqlite3
REGISTRY_DB_PATH=data/registry.sqlite3

# LLM PROVIDER
LLM_PROVIDER=mistral
LLM_MODEL=mistral-small-latest

# GEMINI
GEMINI_API_KEY=

# MISTRAL
MISTRAL_API_KEY=

# HUGGINGFACE
HUGGINGFACE_API_KEY=

# OPENAI (optional)
OPENAI_API_KEY=

# EMBEDDINGS
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

TEMPERATURE=0

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_TOP_K=4
RETRIEVER_FETCH_K=12
MULTI_QUERY_COUNT=3
RERANK_TOP_K=4

ENABLE_MULTI_QUERY=true
ENABLE_RERANKING=true
ENABLE_QUERY_REWRITE=true
